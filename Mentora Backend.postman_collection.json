					"name": "Signup - Parent",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.environment.set('parent_email', 'rahul.sharma@gmail.com');",
									"pm.environment.set('parent_password', 'rahul@1234');",
									"console.log('Signing up parent:', pm.environment.get('parent_email'));"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test('Token saved', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('token');",
									"    pm.environment.set('parent_token', json.token);",
									"    pm.environment.set('parent_id', json._id);",
									"    console.log('Parent token saved');",
									"});",
									"pm.test('Role is parent', function () {",
									"    pm.expect(pm.response.json().role).to.eql('parent');",
									"});"
								]
							}
